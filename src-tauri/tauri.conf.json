{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "transaction-processor",
  "version": "0.1.0",
  "identifier": "com.transaction-processor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Transaction Processor",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc://localhost https://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src ipc://localhost https://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
